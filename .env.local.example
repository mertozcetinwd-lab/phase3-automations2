# Copy to .env.local for `trigger.dev dev`. In production, set these in the
# Trigger.dev dashboard (Environment Variables), NOT here — the cloud worker
# does not read local .env files.

# Anthropic (report generation)
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (defaults to claude-sonnet-5; upgrade: claude-opus-4-8)
# REPORT_MODEL=claude-opus-4-8

# Google Drive service account — the entire JSON key on ONE line
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"svc@project.iam.gserviceaccount.com",...}

# Target Drive folder (shared with the service-account email, or a Shared Drive folder)
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# NOTE: n8n authenticates its trigger call with your Trigger.dev secret key
# (TRIGGER_SECRET_KEY) — that lives in n8n, not here.
